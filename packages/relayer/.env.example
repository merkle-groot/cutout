# Relayer process configuration. Copy to .env and fill. Never commit .env.
#
# NOTE: public chain metadata, entrypoint, ASP pools, and supported assets live in the JSON file
# that CONFIG_PATH points at. RPC URLs and signer keys live here because they may contain secrets.

# --- Required ---
# Which JSON config to load. Without it the relayer looks for ./config.json and exits if missing.
CONFIG_PATH=./config.sepolia.json

# --- RPC endpoints (required) ---
# One variable per `chains[].chain_id` and `destinations[].key` in the JSON config.
# JSON `rpc_url` fields are rejected so provider credentials cannot be stored there.
CHAIN_11155111_RPC_URL=https://your-ethereum-sepolia-rpc.example
DESTINATION_OP_RPC_URL=https://your-op-sepolia-rpc.example
DESTINATION_BASE_RPC_URL=https://your-base-sepolia-rpc.example
DESTINATION_ARB_RPC_URL=https://your-arbitrum-sepolia-rpc.example
DESTINATION_STARKNET_RPC_URL=https://your-starknet-sepolia-rpc.example
# config.example.json also includes a local chain:
# CHAIN_31337_RPC_URL=http://127.0.0.1:8545

# --- Server ---
PORT=8788
HOST=0.0.0.0

# --- Testnet ASP ---
# Mirrors every configured pool's deposit labels into the Entrypoint's ASP root, and serves
# /relayer/asp/proof/:label. Without this the ASP endpoints 404 and withdrawals cannot prove
# association. The signer must hold the ASP_POSTMAN role AND have gas, or the root never publishes
# (the proof still returns, but the pool then rejects the withdrawal with IncorrectASPRoot).
TESTNET_ASP_MODE=true
# How often to re-scan for new labels (ms).
TESTNET_ASP_POLL_MS=10000
# TESTNET_ASP_IPFS_CID=testnet-asp-root-all-labels-placeholder

# --- Secret overrides (optional) ---
# Take precedence over chains[].signer_private_key and defaults.signer_private_key in the JSON
# config. Use these to keep the key out of a committed-ish config file.
# RELAYER_PRIVATE_KEY=0x...
# RELAYER_SIGNER_PRIVATE_KEY=0x...
# RELAYER_FEE_RECEIVER_ADDRESS=0x...

# --- Destination (L2 pool) signers ---
# The relayer is the ONLY component that signs. The app server proxies every write here.
# One key per destination `key` in the JSON config's `destinations` array, uppercased.
# These do NOT fall back to RELAYER_PRIVATE_KEY: that is the L1 entrypoint signer, and
# silently reusing it across chains makes one compromised key every chain's key.
# DESTINATION_OP_PRIVATE_KEY=0x...
# DESTINATION_BASE_PRIVATE_KEY=0x...
# DESTINATION_ARB_PRIVATE_KEY=0x...
# DESTINATION_STARKNET_PRIVATE_KEY=0x...

# --- Automatic note activation ---
# The relayer does NOT poll. The app server scans for backed pending notes and POSTs
# them to /relayer/destinations/:key/activate; the relayer re-verifies each one against
# fresh chain state before signing. Scan cadence is configured on the app server
# (L2_SCAN_BLOCKS_PER_POLL + per-chain block times).

# --- Starknet ---
# Events per getEvents page.
# STARKNET_EVENT_CHUNK=100
# Override the withdrawL2 verifying key path (needed if the circuits build is not at
# ../circuits/build relative to this package, e.g. in a Docker image).
# WITHDRAW_L2_VKEY_PATH=/app/circuits/build/withdrawL2/groth16_vkey.json

# --- RPC rate limiting ---
# Max concurrent RPC calls per endpoint URL. The relayer only reads on demand now (one
# batched check per activation request), so this rarely binds — but it still caps bursts
# when many requests land at once.
#
# SHARED WITH THE APP SERVER: app/server reads the same variable name. Both processes
# hit the same endpoints, so a per-endpoint budget only means something if one value
# tunes both. Set it to the same number in both .env files.
# RPC_CONCURRENCY=1
#
# (RPC_HEAD_TTL_MS is no longer read here — the relayer has no head cache since it
# stopped polling. The app server still reads it.)

# --- Misc ---
# NODE_ENV=production
# RELAYER_HOST=testnet-relayer.privacypools.com
