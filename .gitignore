# General
yarn-error.log
node_modules
.DS_STORE
.vscode
.idea
.worktrees/

# Config files
.env

# Avoid ignoring gitkeep
!/**/.gitkeep

# Cursor rules files
.cursorrules*

# All markdown is local-only. The root README is the single tracked document; every
# other .md (CLAUDE.md, PROGRESS.md, FIXES.md, SECURITY.md, package READMEs, design
# notes, agent scratch files) stays on disk and out of the index.
#
# The leading slash in `!/README.md` is load-bearing: a bare `!README.md` would also
# un-ignore every nested README.md (app/, packages/*/). Anchoring it to the repo root
# keeps the negation to this one file.
*.md
!/README.md

# The docs/ tree (Docusaurus site + design documents) is local-only and untracked.
# It was removed from the index with `git rm -r --cached docs`; the files remain on
# disk. Listed after the *.md rules so it wins for everything underneath it.
docs/
