# Foundry deployment configuration. Never commit a real private key.
ETHEREUM_SEPOLIA_RPC=https://sepolia.infura.io/v3/your_infura_project_id
OP_SEPOLIA_RPC=https://optimism-sepolia.infura.io/v3/your_infura_project_id

DEPLOYER_ADDRESS=0x0000000000000000000000000000000000000000
OWNER_ADDRESS=0x0000000000000000000000000000000000000000
POSTMAN_ADDRESS=0x0000000000000000000000000000000000000000

# Filled after L1 deployment.
ENTRYPOINT_ADDRESS=0x0000000000000000000000000000000000000000
L1_POOL_ADDRESS=0x0000000000000000000000000000000000000000

# Target-specific deployment inputs. Repeat this block with a different prefix for each L2.
L2_TARGET=OP_SEPOLIA
OP_SEPOLIA_L2_MESSENGER_ADDRESS=0x4200000000000000000000000000000000000007
OP_SEPOLIA_L1_MESSENGER_ADDRESS=0x58Cc85b8D04EA49cC6DBd3CbFFd00B4B8D6cb3ef
OP_SEPOLIA_L1_STANDARD_BRIDGE_ADDRESS=0xFBb0621E0B23b5478B630BD55a5f21f67730B0F1
OP_SEPOLIA_L2_POOL_ADDRESS=0x0000000000000000000000000000000000000000
OP_SEPOLIA_CHAIN_ID=11155420
OP_SEPOLIA_MESSAGE_GAS_LIMIT=200000
OP_SEPOLIA_TOKEN_GAS_LIMIT=200000
OP_SEPOLIA_MAX_RELAY_FEE_BPS=100
OP_SEPOLIA_RELAYER_ADDRESS=0x0000000000000000000000000000000000000000
OP_SEPOLIA_BRIDGE_GAS_LIMIT=200000

# Operational L1 updates / relayer funding.
ASP_ROOT=0
ASP_IPFS_CID=testnet-asp-root-all-labels-placeholder
L1_MINIMUM_DEPOSIT_WEI=1000000000000000
L1_VETTING_FEE_BPS=100
L1_MAX_RELAY_FEE_BPS=100
BRIDGE_AMOUNT_WEI=1000000000000000

# Optional ERC20-mode L2 asset; omit for native ETH.
# OP_SEPOLIA_L2_ASSET_ADDRESS=0x0000000000000000000000000000000000000000
